# USAJobs API credentials — request at https://developer.usajobs.gov/apirequest/
# User-Agent must be the email you registered with.
USAJOBS_USER_AGENT=your-email@example.com
USAJOBS_API_KEY=your-api-key-here

# Postgres. If unset, worker falls back to a local SQLite file (gettajob.db).
# For Vercel + Neon, this is the pooled connection string (postgresql://...?sslmode=require).
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Anthropic API key for the Should-I-Apply scorer.
# ANTHROPIC_API_KEY=sk-ant-...

# Gmail IMAP for `gettajob gmail-scan` — reads LinkedIn/Indeed/recruiter alerts.
# Requires 2FA + an app password from https://myaccount.google.com/apppasswords
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
